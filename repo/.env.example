# MotorLot DealerOps Environment Configuration
# Copy to .env and set your own values.

# Server
NODE_ENV=development
PORT=5000
LOG_LEVEL=info

# Database
MONGODB_URI=mongodb://mongodb:27017/motorlot?replicaSet=rs0&directConnection=true
REDIS_URL=redis://redis:6379

# Secrets — MUST be changed for production
JWT_SECRET=<generate-a-secure-random-string>
JWT_REFRESH_SECRET=<generate-a-secure-random-string>
HMAC_SECRET=<generate-a-secure-random-string>

MASTER_ENCRYPTION_KEY=<64-hex-character-string>

# File Storage
UPLOAD_DIR=/app/uploads
QUARANTINE_DIR=/app/quarantine

# Seed Admin Account — created on first startup
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=<strong-password>
ADMIN_FIRST_NAME=Admin
ADMIN_LAST_NAME=User

# Seed Staff Account
STAFF_EMAIL=staff@example.com
STAFF_PASSWORD=<strong-password>
STAFF_FIRST_NAME=Staff
STAFF_LAST_NAME=User

# Seed Finance Reviewer Account
FINANCE_EMAIL=finance@example.com
FINANCE_PASSWORD=<strong-password>
FINANCE_FIRST_NAME=Finance
FINANCE_LAST_NAME=Reviewer

# Seed Buyer Account
BUYER_EMAIL=buyer@example.com
BUYER_PASSWORD=<strong-password>
BUYER_FIRST_NAME=Buyer
BUYER_LAST_NAME=User
